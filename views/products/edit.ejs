<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>Edit Product</title>
    <link rel="stylesheet" href="/css/styles.css">
</head>
<body>
    <main class="container">
        <h1>Edit Product</h1>

        <a href="/products/<%= product.id %>">Back to Product Details</a>

        <% if (errors.length > 0) { %>
            <ul>
                <% errors.forEach((error) => { %>
                    <li><%= error %></li>
                <% }) %>
            </ul>
        <% } %>

        <form action="/products/<%= product.id %>/update" method="POST">
            <p>
                <label for="name">Name</label>
                <input
                    type="text"
                    id="name"
                    name="name"
                    value="<%= product.name || '' %>"
                    required
                >
            </p>

            <p>
                <label for="category">Category</label>
                <input
                    type="text"
                    id="category"
                    name="category"
                    value="<%= product.category || '' %>"
                    required
                >
            </p>

            <p>
                <label for="brand">Brand</label>
                <input
                    type="text"
                    id="brand"
                    name="brand"
                    value="<%= product.brand || '' %>"
                >
            </p>

            <p>
                <label for="price">Price</label>
                <input
                    type="number"
                    id="price"
                    name="price"
                    min="0"
                    step="0.01"
                    value="<%= product.price || '' %>"
                    required
                >
            </p>

            <p>
                <label for="stockQuantity">Stock Quantity</label>
                <input
                    type="number"
                    id="stockQuantity"
                    name="stockQuantity"
                    min="0"
                    step="1"
                    value="<%= product.stockQuantity || '' %>"
                    required
                >
            </p>

            <p>
                <label>
                    <input
                        type="checkbox"
                        name="available"
                        <% if (product.available) { %>checked<% } %>
                    >
                    Available
                </label>
            </p>

            <button type="submit">Update Product</button>
        </form>
    </main>
</body>
</html>